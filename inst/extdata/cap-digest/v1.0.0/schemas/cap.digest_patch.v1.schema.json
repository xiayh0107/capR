{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cap-spec.org/schemas/cap.digest_patch.v1.schema.json",
  "title": "CAP-Digest Patch v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "patchId", "baseDigestId", "baseFingerprint", "budgetDelta", "operations", "manifestRows"],
  "properties": {
    "schema": { "const": "cap.digest_patch.v1" },
    "patchId": { "type": "string", "minLength": 1 },
    "baseDigestId": { "type": "string", "minLength": 1 },
    "baseFingerprint": { "type": "string", "minLength": 1 },
    "budgetDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["estimated", "used"],
      "properties": {
        "estimated": { "type": "integer", "minimum": 0 },
        "used": { "type": "integer", "minimum": 0 }
      }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/op" }
    },
    "manifestRows": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    }
  },
  "$defs": {
    "op": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "fieldId", "fieldBlock"],
          "properties": {
            "op": { "const": "add_selected_field" },
            "fieldId": { "type": "string" },
            "fieldBlock": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "fieldId"],
          "properties": {
            "op": { "const": "remove_available_on_request" },
            "fieldId": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "line"],
          "properties": {
            "op": { "const": "add_caveat_line" },
            "line": { "type": "string", "minLength": 1 }
          }
        }
      ]
    }
  }
}
