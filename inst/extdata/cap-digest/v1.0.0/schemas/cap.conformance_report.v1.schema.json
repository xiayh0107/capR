{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cap-spec.org/schemas/cap.conformance_report.v1.schema.json",
  "title": "CAP Conformance Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "ok", "checks"],
  "properties": {
    "schema": { "const": "cap.conformance_report.v1" },
    "implementation": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "capVersion": { "type": "string", "minLength": 1 },
    "level": { "type": "integer", "minimum": 0 },
    "ok": { "type": "boolean" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "ok", "problems"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "ok": { "type": "boolean" },
          "problems": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
