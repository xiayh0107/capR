{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cap-spec.org/schemas/cap.field.v1.schema.json",
  "title": "CAP-Digest Field v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "label", "description", "sourceTypes", "timing", "trust", "exec", "levels"],
  "properties": {
    "schema": { "const": "cap.field.v1" },
    "id": { "type": "string", "pattern": "^f1:.+@.+#.+$" },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "sourceTypes": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
    "timing": { "enum": ["assemble", "interactive"] },
    "trust": { "enum": ["code", "derived", "data"] },
    "exec": { "enum": ["local_cheap", "local_scan", "remote_query", "unsafe"] },
    "nonMonotonic": { "type": "boolean", "default": false },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "extractor": { "type": "string" },
        "redactor": { "type": "string" },
        "renderer": { "type": "string" }
      }
    },
    "selectionHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "priorValue": { "type": "number" },
        "intentTags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["level", "estimatedCost", "description"],
        "properties": {
          "level": { "type": "integer", "minimum": 1 },
          "estimatedCost": { "type": "integer", "minimum": 0 },
          "description": { "type": "string" }
        }
      }
    }
  }
}
